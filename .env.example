# =======================================================
# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!
# =======================================================

# -------------------------------------------------------
# DATABASE CONFIGURATION
# -------------------------------------------------------

# For Docker Compose LOCAL development:
# Uses 'db' as hostname (Docker resolves service names automatically)
DATABASE_URL=postgresql://postgres:yourpassword@db:5432/mobile_productivity

# For Render.com PRODUCTION (uncomment and fill in):
# DATABASE_URL=postgres://user:password@host.render.com:5432/dbname?sslmode=require

# For Docker Compose (individual credentials used in docker-compose.yml):
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=mobile_productivity

# -------------------------------------------------------
# APPLICATION
# -------------------------------------------------------
RUST_LOG=info
PORT=8080

# -------------------------------------------------------
# SECURITY
# -------------------------------------------------------
# Change this to a strong random secret in production!
# Generate one with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# -------------------------------------------------------
# SUPABASE (if using Supabase Storage for APK/files)
# -------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
